<section class="ui left aligned middle aligned segment">

  {{> dashboardHeader }}

  {{#unless search}}
    {{#unless creatures}}
    <h3 class="ui message">
      Start adding your sea creatures!
    </h3>
    <br>
    {{/unless}}
  {{/unless}}

  <div class="ui centered cards">
    
    {{#each creatures}}
      {{> creatureCard}}
    {{/each}}
    
  </div>

</section>
